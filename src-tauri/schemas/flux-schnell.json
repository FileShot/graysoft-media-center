{
  "id": "flux-schnell",
  "name": "Flux Schnell",
  "mediaType": "image",
  "groups": [
    {
      "id": "prompt",
      "label": "Prompt",
      "fields": [
        {
          "id": "prompt",
          "label": "Prompt",
          "type": "text",
          "default": "",
          "bindings": [{ "nodeId": "6", "input": "text" }]
        },
        {
          "id": "negative_prompt",
          "label": "Negative Prompt",
          "type": "text",
          "default": "",
          "bindings": [{ "nodeId": "7", "input": "text" }]
        }
      ]
    },
    {
      "id": "dimensions",
      "label": "Dimensions",
      "fields": [
        {
          "id": "width",
          "label": "Width",
          "type": "number",
          "default": 1024,
          "min": 256,
          "max": 2048,
          "step": 64,
          "bindings": [{ "nodeId": "19", "input": "width", "transform": "int" }]
        },
        {
          "id": "height",
          "label": "Height",
          "type": "number",
          "default": 1024,
          "min": 256,
          "max": 2048,
          "step": 64,
          "bindings": [{ "nodeId": "19", "input": "height", "transform": "int" }]
        },
        {
          "id": "batch_size",
          "label": "Batch Size",
          "type": "slider",
          "default": 1,
          "min": 1,
          "max": 4,
          "step": 1,
          "bindings": [{ "nodeId": "19", "input": "batch_size", "transform": "int" }]
        }
      ]
    },
    {
      "id": "quality",
      "label": "Quality",
      "fields": [
        {
          "id": "steps",
          "label": "Steps",
          "type": "slider",
          "default": 4,
          "min": 1,
          "max": 8,
          "step": 1,
          "bindings": [{ "nodeId": "3", "input": "steps", "transform": "int" }]
        },
        {
          "id": "cfg",
          "label": "CFG Scale",
          "type": "slider",
          "default": 1.0,
          "min": 0.5,
          "max": 3.0,
          "step": 0.1,
          "bindings": [{ "nodeId": "3", "input": "cfg" }]
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "seed",
          "default": -1,
          "bindings": [{ "nodeId": "3", "input": "seed", "transform": "seed" }]
        },
        {
          "id": "sampler_name",
          "label": "Sampler",
          "type": "select",
          "default": "euler",
          "options": [
            { "label": "Euler", "value": "euler" },
            { "label": "Euler Ancestral", "value": "euler_ancestral" },
            { "label": "DPM++ 2M", "value": "dpmpp_2m" }
          ],
          "bindings": [{ "nodeId": "3", "input": "sampler_name", "transform": "string" }]
        },
        {
          "id": "scheduler",
          "label": "Scheduler",
          "type": "select",
          "default": "simple",
          "options": [
            { "label": "Simple", "value": "simple" },
            { "label": "Normal", "value": "normal" },
            { "label": "Karras", "value": "karras" }
          ],
          "bindings": [{ "nodeId": "3", "input": "scheduler", "transform": "string" }]
        }
      ]
    },
    {
      "id": "advanced",
      "label": "Advanced",
      "fields": [
        {
          "id": "unet_name",
          "label": "UNET Model",
          "type": "text",
          "default": "flux1-schnell.safetensors",
          "bindings": [{ "nodeId": "12", "input": "unet_name", "transform": "string" }]
        },
        {
          "id": "denoise",
          "label": "Denoise",
          "type": "slider",
          "default": 1.0,
          "min": 0.1,
          "max": 1.0,
          "step": 0.05,
          "bindings": [{ "nodeId": "3", "input": "denoise" }]
        }
      ]
    }
  ]
}
