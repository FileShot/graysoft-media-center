{
  "id": "ltx-video-2",
  "name": "LTX-Video 2",
  "mediaType": "video",
  "groups": [
    {
      "id": "prompt",
      "label": "Prompt",
      "fields": [
        {
          "id": "prompt",
          "label": "Prompt",
          "type": "text",
          "default": "",
          "bindings": [{ "nodeId": "2", "input": "text" }]
        },
        {
          "id": "negative_prompt",
          "label": "Negative Prompt",
          "type": "text",
          "default": "",
          "bindings": [{ "nodeId": "3", "input": "text" }]
        }
      ]
    },
    {
      "id": "dimensions",
      "label": "Dimensions",
      "fields": [
        {
          "id": "width",
          "label": "Width",
          "type": "number",
          "default": 768,
          "min": 512,
          "max": 1280,
          "step": 64,
          "bindings": [{ "nodeId": "4", "input": "width", "transform": "int" }]
        },
        {
          "id": "height",
          "label": "Height",
          "type": "number",
          "default": 512,
          "min": 512,
          "max": 768,
          "step": 64,
          "bindings": [{ "nodeId": "4", "input": "height", "transform": "int" }]
        }
      ]
    },
    {
      "id": "video",
      "label": "Video",
      "fields": [
        {
          "id": "duration",
          "label": "Duration (seconds)",
          "type": "slider",
          "default": 5,
          "min": 2,
          "max": 12,
          "step": 0.5,
          "bindings": []
        },
        {
          "id": "fps",
          "label": "FPS",
          "type": "select",
          "default": 24,
          "options": [
            { "label": "24 fps", "value": 24 },
            { "label": "30 fps", "value": 30 },
            { "label": "16 fps", "value": 16 }
          ],
          "bindings": [{ "nodeId": "5", "input": "frame_rate", "transform": "int" }]
        },
        {
          "id": "num_frames",
          "label": "Frame Count",
          "type": "number",
          "default": 121,
          "min": 24,
          "max": 360,
          "step": 1,
          "bindings": [{ "nodeId": "4", "input": "num_frames", "transform": "int" }]
        },
        {
          "id": "temporal_consistency",
          "label": "Temporal Consistency",
          "type": "slider",
          "default": 0.8,
          "min": 0.0,
          "max": 1.0,
          "step": 0.05,
          "bindings": [{ "nodeId": "4", "input": "temporal_consistency" }]
        }
      ]
    },
    {
      "id": "quality",
      "label": "Quality",
      "fields": [
        {
          "id": "steps",
          "label": "Steps",
          "type": "slider",
          "default": 30,
          "min": 10,
          "max": 50,
          "step": 1,
          "bindings": [{ "nodeId": "4", "input": "steps", "transform": "int" }]
        },
        {
          "id": "cfg",
          "label": "CFG Scale",
          "type": "slider",
          "default": 3.0,
          "min": 1.0,
          "max": 8.0,
          "step": 0.5,
          "bindings": [{ "nodeId": "4", "input": "cfg" }]
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "seed",
          "default": -1,
          "bindings": [{ "nodeId": "4", "input": "seed", "transform": "seed" }]
        }
      ]
    },
    {
      "id": "advanced",
      "label": "Advanced",
      "fields": [
        {
          "id": "ckpt_name",
          "label": "LTX Checkpoint",
          "type": "text",
          "default": "ltxv-2b-0.9.5.safetensors",
          "bindings": [{ "nodeId": "1", "input": "ckpt_name", "transform": "string" }]
        }
      ]
    }
  ]
}
