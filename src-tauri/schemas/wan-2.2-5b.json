{
  "id": "wan-2.2-5b",
  "name": "WAN 2.2 5B",
  "mediaType": "video",
  "groups": [
    {
      "id": "prompt",
      "label": "Prompt",
      "fields": [
        {
          "id": "prompt",
          "label": "Prompt",
          "type": "text",
          "default": "",
          "bindings": [{ "nodeId": "2", "input": "text" }]
        },
        {
          "id": "negative_prompt",
          "label": "Negative Prompt",
          "type": "text",
          "default": "",
          "bindings": [{ "nodeId": "3", "input": "text" }]
        }
      ]
    },
    {
      "id": "dimensions",
      "label": "Dimensions",
      "fields": [
        {
          "id": "width",
          "label": "Width",
          "type": "number",
          "default": 672,
          "min": 480,
          "max": 832,
          "step": 16,
          "bindings": [{ "nodeId": "4", "input": "width", "transform": "int" }]
        },
        {
          "id": "height",
          "label": "Height",
          "type": "number",
          "default": 384,
          "min": 384,
          "max": 480,
          "step": 16,
          "bindings": [{ "nodeId": "4", "input": "height", "transform": "int" }]
        }
      ]
    },
    {
      "id": "video",
      "label": "Video",
      "fields": [
        {
          "id": "fps",
          "label": "FPS",
          "type": "select",
          "default": 16,
          "options": [
            { "label": "16 fps", "value": 16 },
            { "label": "24 fps", "value": 24 }
          ],
          "bindings": [{ "nodeId": "5", "input": "frame_rate", "transform": "int" }]
        },
        {
          "id": "frame_count",
          "label": "Frame Count",
          "type": "number",
          "default": 33,
          "min": 16,
          "max": 81,
          "step": 1,
          "bindings": [{ "nodeId": "4", "input": "frame_count", "transform": "int" }]
        }
      ]
    },
    {
      "id": "ti2v",
      "label": "Image-to-Video",
      "fields": [
        {
          "id": "reference_image",
          "label": "Reference Image",
          "type": "file",
          "default": "",
          "bindings": [{ "input": "reference_image" }]
        },
        {
          "id": "lora_path",
          "label": "LoRA adapter (optional)",
          "type": "file",
          "default": "",
          "bindings": [{ "input": "lora_path" }]
        }
      ]
    },
    {
      "id": "quality",
      "label": "Quality",
      "fields": [
        {
          "id": "steps",
          "label": "Steps",
          "type": "slider",
          "default": 16,
          "min": 8,
          "max": 40,
          "step": 1,
          "bindings": [{ "nodeId": "4", "input": "steps", "transform": "int" }]
        },
        {
          "id": "cfg",
          "label": "CFG Scale",
          "type": "slider",
          "default": 3.5,
          "min": 1.0,
          "max": 8.0,
          "step": 0.5,
          "bindings": [{ "nodeId": "4", "input": "cfg" }]
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "seed",
          "default": -1,
          "bindings": [{ "nodeId": "4", "input": "seed", "transform": "seed" }]
        }
      ]
    }
  ]
}
